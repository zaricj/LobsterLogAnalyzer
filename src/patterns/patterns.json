{
  "exception_patterns": {
    "sql_datatype_mismatch": "java\\.sql\\.SQLException: Data type mismatch",
    "sql_duplicate_key": "\\[SQL0803] Doppelter Schlüsselwert angegeben",
    "sql_data_conversion": "\\[SQL0802] Fehler bei Datenumsetzung",
    "sql_multiple_rows": "\\[SQL0811] Ergebnis der Anweisung enthält mehr als eine Zeile",
    "sql_syntax_error": "AS400JDBCSQLSyntaxErrorException: \\[SQL0104] Token",
    "sql_nontransient_connection": "java\\.sql\\.SQLNonTransientConnectionException",
    "sql_generic": "java\\.sql\\.SQLException",
    "as400_jdbc": "com\\.ibm\\.as400\\.access\\.[A-Za-z0-9]+Exception",
    "as400_generic": "com\\.ibm\\.as400\\.access\\.",
    "mariadb_socket": "Socket error",
    "socket_reset": "java\\.net\\.SocketException: Connection reset by peer",
    "socket_timeout": "java\\.net\\.SocketTimeoutException: Read timed out",
    "timeout": "TimeoutException",
    "nullpointer": "java\\.lang\\.NullPointerException",
    "uncaught": "UNCAUGHTEXCEPTIONHANLDER",
    "ftp_store_failed": "Unable to store file .*?user=",
    "ftp_timeout": "java\\.net\\.SocketTimeoutException: Read timed out"
  },

  "sql_statement_pattern": "exception on sql statement:\\s*(?P<sql>.+?)(?=(?:\\n[A-Z][a-z]+\\.|\\nParam|\\Z))",

  "entry_header_pattern": "(?P<time>\\d{2}:\\d{2}:\\d{2})\\s+(?P<source>[A-Z]+:[A-Z:]+(?:\\([^)]+\\))?)\\s+(?P<error_block>.+?)(?=\\n\\d{2}:\\d{2}:\\d{2}\\s+[A-Z]+:[A-Z:]|\\Z)",

  "param_pattern": "Param for failed sql statement\\s+\\[(?P<param>[^\\]]+)]\\s+'(?P<value>[^']+)'",

  "caused_by_pattern": "^\\s*Caused by:\\s*(?P<cause>[^\\n]*)",

  "ignore_stacktrace_pattern": "^\\s*at\\s+[\\w.$]+\\(.*\\)$"
}
