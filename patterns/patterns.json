{
  "sql_exceptions": {
    "base": {
      "header": "^(?P<time>\\d{2}:\\d{2}:\\d{2})"
    },
    "patterns": {
      "default": "(?s)exception on sql statement:\\s*(?P<sql_query>.+?)\\s*\\(transformed to.*?java\\.sql\\.[^:]+:\\s*(?P<error_details>.*?)(?:\\s+for statement|$).*?Caused by:\\s*java\\.sql\\.[^:]+:\\s*(?P<caused_by>[^\\n]*)"
    }
  }
}